rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function hasValidAppointmentService(service) {
      return service is map &&
        isNonEmptyString(service.key) &&
        isNonEmptyString(service.label);
    }

    function hasValidAppointmentPayload(data) {
      return isNonEmptyString(data.projectId) &&
        isNonEmptyString(data.tenantId) &&
        isNonEmptyString(data.requestId) &&
        isNonEmptyString(data.contactId) &&
        isNonEmptyString(data.tenantSlug) &&
        isNonEmptyString(data.serviceId) &&
        isNonEmptyString(data.serviceNameSnapshot) &&
        isNonEmptyString(data.date) &&
        isNonEmptyString(data.time) &&
        isNonEmptyString(data.customerName) &&
        isNonEmptyString(data.customerPhone) &&
        isNonEmptyString(data.status) &&
        hasValidAppointmentService(data.service);
    }

    // Etapa atual do Core:
    // ainda estamos sem autenticação e autorização por tenant, então as regras
    // seguem abertas para desenvolvimento. Mesmo assim, reduzimos a superfície de
    // escrita e deixamos explícito que `Project` é a raiz do escopo operacional.
    //
    // Próxima etapa:
    // convergir para auth + autorização por projeto/perfil, removendo leitura e
    // escrita públicas.
    match /projects/{projectId} {
      allow read, create: if true;
    }

    // `botProfiles` guarda a configuração conversacional principal por projeto.
    // Nesta etapa o painel precisa ler e fazer upsert do documento do tenant.
    match /botProfiles/{projectId} {
      allow read, create, update: if true;
    }

    match /contacts/{contactId} {
      allow read: if true;
    }

    match /inboundEvents/{eventId} {
      allow read: if true;
    }

    match /projectConnections/{connectionId} {
      allow read, create, update: if true;
    }

    // Fonte oficial de serviços reais exibidos no WhatsApp nesta fase.
    // O Core/bot consulta `agendamento-ai-9fbfb/services` por tenant; a gestão
    // do catálogo continua pertencendo ao admin operacional da agenda.
    match /services/{serviceId} {
      allow read: if true;
    }

    // `serviceRequests` passa a ser a porta de entrada principal do core.
    match /serviceRequests/{serviceRequestId} {
      allow read, update: if true;
    }

    // `integrationEvents` e `integrationLogs` materializam a observabilidade
    // outbound do Core. O sistema externo continua sendo a fonte de verdade do
    // domínio integrado; aqui registramos a orquestração operacional.
    match /integrationEvents/{integrationEventId} {
      allow read, create, update: if true;
    }

    match /integrationLogs/{integrationLogId} {
      allow read, create: if true;
    }

    match /appointments/{appointmentId} {
      // `appointments` agora é apenas um espelho operacional local opcional.
      // O Core não assume mais a verdade autoritativa do agendamento, mas
      // quando materializa um mirror local ele precisa preservar o tenant e o
      // serviço de origem para leituras posteriores consistentes.
      allow read: if true;
      allow create, update: if hasValidAppointmentPayload(request.resource.data);
    }

    // Coleção legada mantida durante a migração gradual.
    match /appointmentRequests/{requestId} {
      allow read: if true;
    }
  }
}
